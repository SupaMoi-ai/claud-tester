# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Provider mode ---
# mock = no paid APIs called; deterministic seed data
# real = use the keys below
PROVIDER_MODE=mock

# --- Pinterest (used when PROVIDER_MODE=real) ---
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/api/auth/pinterest/callback

# --- Replicate (CLIP embeddings) ---
REPLICATE_API_TOKEN=

# --- OpenAI (vision + LLM) ---
OPENAI_API_KEY=
